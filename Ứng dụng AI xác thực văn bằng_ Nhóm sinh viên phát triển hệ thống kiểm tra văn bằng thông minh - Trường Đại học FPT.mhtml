.value-card { background: transparent; padding: 3px; position: relative; }

.card-inner { padding: 40px 15px 50px; height: 100%; min-height: 350px; pos=
ition: relative; clip-path: polygon(0px 0px, calc(100% - 50px) 0px, 100% 50=
