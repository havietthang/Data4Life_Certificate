45deg); display: inline-block; }

.card-title { font-size: 21px; font-weight: 700; color: rgb(244, 118, 40); =
margin: 0px 0px 18px; line-height: 1.4; z-index: 99; height: 30px; }

.card-text { font-size: 15px; line-height: 1.7; color: rgb(0, 0, 0); margin=
: 0px; flex-grow: 1; z-index: 99; }

.card-decoration { position: absolute; bottom: 22px; right: 22px; width: 65=
px; height: 8px; background-image: repeating-linear-gradient(45deg, rgb(229=
, 229, 229) 0px, rgb(229, 229, 229) 6px, transparent 6px, transparent 12px)=
; }

.seemore { position: absolute; bottom: -50px; z-index: 999; opacity: 0; tra=
nsition: 0.4s; }

.value-card:hover .seemore { bottom: 35px; opacity: 1; transition: 0.4s; }

.bg-img-life { position: absolute; bottom: 0px; right: 0px; z-index: 1; wid=
th: 100%; height: 100%; }

.bg-img-life::after { content: ""; background: rgba(0, 0, 0, 0.6); width: 1=
00%; height: 100%; left: 0px; z-index: 2; position: absolute; }

